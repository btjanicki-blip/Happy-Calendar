{
  "name": "gamified-calendar",
  "private": true,
  "version": "1.0.0",
  "productName": "Happy Calendar",
  "scripts": {
    "install:all": "npm install --prefix client && npm install --prefix server",
    "dev": "npm run dev:server",
    "dev:client": "npm run dev --prefix client",
    "dev:server": "npm run dev --prefix server",
    "build": "npm run build --prefix client",
    "build:vercel": "npm run build:vercel --prefix client",
    "start": "npm run start --prefix server",
    "start:web": "npm run build && npm start",
    "preview": "npm run preview --prefix client",
    "test:client": "npm run test --prefix client",
    "test:server": "npm run test --prefix server"
  }
}
